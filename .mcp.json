{
  "mcpServers": {
    "chakra-ui": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@chakra-ui/react-mcp"]
    },
    "react-icons": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "react-icons-mcp", "--stdio"]
    },
    "next-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "next-devtools-mcp"]
    },
    "crowdin": {
      "type": "http",
      "url": "https://mcp.crowdin.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${CROWDIN_PERSONAL_TOKEN}"
      }
    },
    "claude-design": {
      "type": "http",
      "url": "https://api.anthropic.com/v1/design/mcp"
    }
  }
}
